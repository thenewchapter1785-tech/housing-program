SEARCH_CITY=seattle
SEARCH_QUERY=studio apartment
DATA_DIR=data
REQUEST_DELAY_SECONDS=2

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=housing_app

# Web runtime security/network
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_ALLOWED_ORIGINS=http://localhost:3000
WEB_SESSION_TTL_HOURS=24
WEB_JWT_SECRET=change-me
WEB_JWT_ALG=HS256
WEB_ACCESS_TTL_MINUTES=30
WEB_REFRESH_TTL_DAYS=14
AUTO_REFRESH_IN_WEB=false

# Automatic area refresh scheduler
AUTO_REFRESH_ENABLED=true
AUTO_REFRESH_INTERVAL_SECONDS=900
AUTO_REFRESH_QUERY=apartment
AUTO_REFRESH_PROVIDERS=craigslist,rentals,padmapper,rightmove

# Desktop mode
DESKTOP_USE_CLI=false
